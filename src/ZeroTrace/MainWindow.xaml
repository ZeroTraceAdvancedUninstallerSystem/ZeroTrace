<Window x:Class="ZeroTrace.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ZeroTrace"
        Height="500"
        Width="820"
        Background="#1E1E1E">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="ZeroTrace"
                       FontSize="30"
                       FontWeight="Bold"
                       Foreground="White"/>
            <TextBlock Text="Privacy Cleanup Console"
                       Margin="0,6,0,0"
                       FontSize="14"
                       Foreground="#BBBBBB"/>
        </StackPanel>

        <StackPanel Grid.Row="2"
                    VerticalAlignment="Top">
            <Button Content="Programme scannen"
                    Height="42"
                    Margin="0,0,0,10"/>
            <Button Content="Deinstallieren + Tiefenreinigung"
                    Height="42"
                    Margin="0,0,0,10"/>
            <Button Content="Vault anzeigen"
                    Height="42"
                    Margin="0,0,0,10"/>
            <Button Content="System bereinigen"
                    Height="42"/>
        </StackPanel>
    </Grid>
</Window>